# Preferred AI provider for this demo
AI_PROVIDER=gemini

# Gemini API Key (optional - the app works offline with fallback content)
# GEMINI_API_KEY=AIza...

# Gemini model to use for generation
GEMINI_MODEL=gemini-2.0-flash

# Gemini model to use for image generation
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# Optional Imagen model used before Gemini Flash image generation
GEMINI_IMAGEN_MODEL=imagen-4.0-generate-001

# Optional approved LinkedIn Talent Solutions / RSC connector settings
# LINKEDIN_RSC_ACCESS_TOKEN=
# LINKEDIN_VERSION=202603
# LINKEDIN_RSC_SEARCH_ENDPOINT=https://api.linkedin.com/rest/...

# OpenAI API Key (optional fallback provider)
# OPENAI_API_KEY=sk-...

# OpenAI model to use for generation
# OPENAI_MODEL=gpt-4o-mini
